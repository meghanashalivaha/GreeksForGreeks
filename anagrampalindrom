class Solution:
    def canFormPalindrome(self, s):
        freq = {}
        for ch in s:
            if ch in freq:
                freq[ch] += 1
            else:
                freq[ch] = 1 
        is_odd=0
        for val in freq.values():
            if val&1==1:
                is_odd+=1
        return is_odd<2
obj=Solution()
s=input()
print(obj.canFormPalindrome(s))
